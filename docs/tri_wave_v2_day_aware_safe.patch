     def __init__(self):
         self.streams=defaultdict(lambda:{k:TriWaveStreamState(stream=k) for k in ("FUT","CE","PE")}); self.pos=defaultdict(TriWavePositionState); self._exit_conf=defaultdict(int); self._last_wait_log=defaultdict(float); self._last_visual=defaultdict(float); self._entry_confirm=defaultdict(lambda:{"side":None,"count":0,"first_ts":0.0,"last_ts":0.0,"last_reason":None}); self._exit_health_memory=defaultdict(lambda:deque(maxlen=12))
+
+    def _expiry_day_profile(self, now: Optional[float] = None) -> dict:
+        dt=datetime.fromtimestamp(now or time.time(), self.MARKET_TZ)
+        profile=dict(self.EXPIRY_DAY_PROFILES.get(dt.weekday(), self.EXPIRY_DAY_PROFILES[2]))
+        profile["weekday"]=dt.weekday()
+        return profile
+
+    def _day_hard_adverse_reason(self, *, now: float, hold: float, pnl_pct: float, gross_points: float, gross_rupees: float) -> tuple[Optional[str], dict]:
+        profile=self._expiry_day_profile(now)
+        if not self.DAY_AWARE_ENABLED:
+            return None,profile
+        if hold<profile["hard_hold_sec"]:
+            return None,profile
+        if gross_points>=0:
+            return None,profile
+        hit_points=gross_points<=-float(profile["hard_loss_points"])
+        hit_pct=pnl_pct<=float(profile["hard_loss_pct"])
+        hit_rupees=gross_rupees<=-float(profile["max_loss_rupees"])
+        if hit_points or hit_pct or hit_rupees:
+            return f"DAY_HARD_ADVERSE:{profile['label']}",profile
+        return None,profile
